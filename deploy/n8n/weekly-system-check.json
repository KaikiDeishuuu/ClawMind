      "parameters": {
        "language": "JavaScript",
        "jsCode": "return [{\n  json: {\n    request_id: `weekly-system-check-${Date.now()}`,\n    mode: 'scheduled',\n    user_id: $json.user_id || 'user_001',\n    channel: 'ops',\n    task: 'weekly_system_check',\n    user_message: '',\n    workflow_context: {\n      workflow_id: 'weekly-system-check',\n      trigger: 'cron',\n      profile: $json.profile,\n      preferences: $json.preferences,\n      health_checks: {\n        openclaw: $json.openclaw_health,\n        memory_api: $json.memory_health,\n      },\n    },\n    tool_context: {\n      notifications_enabled: true,\n    },\n  },\n}];"
      }
    },
    {
