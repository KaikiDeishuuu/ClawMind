        "method": "POST",
        "url": "http://openclaw:8080/respond",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ $json }}",
        "options": {}
      }
    },
    {
      "id": "fa830db8-6eb6-44ae-a0d5-ae35e832ddcd",
      "name": "Dispatch Ops Report",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1900,
        320
      ],
      "parameters": {
        "method": "POST",
        "url": "={{ $env.OPS_WEBHOOK_URL || 'http://host.docker.internal:8090/ops' }}",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ { channel: 'ops', text: $json.response_text, request_id: $json.request_id } }}",
        "options": {}
      }
    },
    {
      "id": "318d1c0c-95cc-468a-bd08-1c75d073f9c5",
      "name": "Has Memory Proposals?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [
        1900,
        520
      ],
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "leftValue": "={{ Array.isArray($json.memory_proposals) ? $json.memory_proposals.length : 0 }}",
              "rightValue": 0,
              "operator": {
                "type": "number",
                "operation": "larger"
              }
            }
          ],
          "combinator": "and"
        }
      }
    },
    {
      "id": "5471d234-6703-47de-a438-03c6b2c5b11b",
      "name": "Prepare Proposal Items",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2140,
        520
      ],
      "parameters": {
        "language": "JavaScript",
        "jsCode": "const proposals = Array.isArray($json.memory_proposals) ? $json.memory_proposals : [];\nreturn proposals.map((proposal) => ({ json: proposal }));"
      }
    },
    {
      "id": "8219ae4b-0e74-4e7f-a87a-60756a60f5f7",
